{
  "permissions": {

    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Task",
      "mcp__*"
    ],

    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)",

      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  }
}